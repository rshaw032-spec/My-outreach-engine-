{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with encrypted API keys",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "encryptedApifyKey": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A generated or scraped lead with their message status",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "profileUrl": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string" },
        "platform": { "type": "string", "enum": ["LinkedIn", "Instagram", "Email"] },
        "score": { "type": "number" },
        "label": { "type": "string", "enum": ["High", "Medium", "Low", "Unscored"] },
        "message": { "type": "string" },
        "followUps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string", "enum": ["Not Sent", "Sent", "Follow-up 1", "Follow-up 2", "Replied", "Skipped"] },
        "lastActionDate": { "type": "number" }
      },
      "required": ["userId", "name", "profileUrl", "platform", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Store user accounts."
    },
    "users/{userId}/leads/{leadId}": {
      "schema": "Lead",
      "description": "Store individual leads generated by the user."
    }
  }
}
